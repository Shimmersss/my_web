# Web 服务器生产环境变量
# 服务器路径建议：/etc/web-homepage/web.env
# 注意：这个文件包含密钥，只放服务器，不提交 git，不放公网。

# Zotero（申请地址：https://www.zotero.org/settings/keys）
ZOTERO_API_KEY=OgWcFLRsPwUjIbwY4CHOaELi
ZOTERO_USER_ID=20482611

# GitHub 开源项目后台管理密钥 + OpenClaw 网页对话登录密钥
ADMIN_KEY=1241420431

# TXT 段落翻译 API（Anthropic Messages API 格式）
LLM_API_URL=https://token-plan-cn.xiaomimimo.com/anthropic
LLM_API_KEY=tp-c48jvin6m1a1p1g050p7248hdlklkixowyng8dhyqajlniz7
LLM_MODEL=mimo-v2.5-pro

# 排版版 PDF 翻译（BabelDOC + OpenAI-compatible API）
# Linux 服务器需要安装 uv：curl -LsSf https://astral.sh/uv/install.sh | sh
BABELDOC_ENABLED=true
BABELDOC_COMMAND="uv run --with babeldoc python"
BABELDOC_OPENAI_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
BABELDOC_OPENAI_API_KEY=tp-c48jvin6m1a1p1g050p7248hdlklkixowyng8dhyqajlniz7
BABELDOC_OPENAI_MODEL=mimo-v2.5-pro
BABELDOC_TIMEOUT_SECONDS=1800
BABELDOC_QPS=8

# OpenClaw Gateway 后端代理（凭证由本机 OpenClaw CLI 读取，不要传给前端）
OPENCLAW_COMMAND=openclaw
OPENCLAW_SESSION_KEY=main
OPENCLAW_TIMEOUT_SECONDS=30
