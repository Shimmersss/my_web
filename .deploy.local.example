# Local one-click deployment settings. Copy to .deploy.local if overrides are needed.
# Do not put server passwords, private keys, API keys, or web.env contents here.

DEPLOY_HOST=115.28.129.221
DEPLOY_USER=admin
DEPLOY_PORT=22
# Use an absolute path to a private key stored outside this project.
# DEPLOY_IDENTITY_FILE=/Users/your-name/.ssh/server-private-key

REMOTE_DIR=/home/admin/web-homepage
REMOTE_UPLOAD_DIR=/home/admin/.web-homepage-releases
CONFIG_DIR=/etc/web-homepage
SERVICE_NAME=web-backen
NGINX_SITE_NAME=corporate-site

DOMAIN=shimmer.help
PUBLIC_URL=https://shimmer.help/
# Used when verifying Nginx through http://127.0.0.1 after deployment.
# LOCAL_SITE_HOST=shimmer.help

# Existing Nginx/Certbot SSL config is preserved by default.
# FORCE_NGINX_CONFIG=0
# RUN_TESTS=1
# REQUIRE_CLEAN=0
# DRY_RUN=0
